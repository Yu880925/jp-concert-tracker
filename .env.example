# 本機開發用，複製為 .env 後填入（勿 commit .env）

# AI 分析（至少設定一個）
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# X API（可選，預設用 Nitter 不需設定）
X_BEARER_TOKEN=

# 資料庫路徑（Render 設為 /var/data/concerts.db）
DB_PATH=concerts.db

# API 保護金鑰（Render + GitHub Actions 必須設定相同值）
SCAN_API_KEY=your-random-secret-here

# 是否允許網頁上的「立即掃描」按鈕（生產環境建議 false）
ENABLE_PUBLIC_SCAN=false

# Render 網址（GitHub Actions 用，例如 https://jp-concert-tracker.onrender.com）
RENDER_URL=
